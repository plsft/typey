{
	"name": "typey",
	"version": "0.1.0",
	"description": "Tiny CLI that converts text between common identifier cases (camel, snake, kebab, pascal).",
	"type": "module",
	"bin": {
		"typey": "./dist/index.js"
	},
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target bun",
		"start": "bun run src/index.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"keywords": ["cli", "case", "text", "snake", "camel", "kebab", "pascal"],
	"license": "MIT",
	"author": "Plural Software",
	"engines": {
		"bun": ">=1.1.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/figlet": "^1.7.0",
		"typescript": "^5.6.0"
	},
	"dependencies": {
		"figlet": "^1.11.0"
	}
}
